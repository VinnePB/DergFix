<Window x:Class="DergFix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DergFix - Ferramenta de Reparo" Width="850"
        SizeToContent="Height"
        Background="#F9F9F9" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image Grid.Column="0" Source="doofus.ico" Width="40" Height="40" Margin="0,0,15,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="DergFix System Repair" FontSize="20" FontWeight="Bold" Foreground="#1F1F1F"/>
                    <TextBlock Text="Varredura de integridade e correção de arquivos corrompidos via SFC." FontSize="12" Foreground="#666" Margin="0,4,0,0"/>
                </StackPanel>
                
                <TextBlock x:Name="lblEstimativa" Grid.Column="2" Text="Pronto para iniciar" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#0078D4"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="progressVarredura" Height="10" Minimum="0" Maximum="100" Value="0" Background="#E0E0E0" Foreground="#0078D4"/>
            <TextBlock x:Name="lblPorcentagem" Grid.Column="1" Text="0%" Width="45" TextAlignment="Right" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center" Margin="10,0,0,0"/>
        </Grid>

        <!-- Adicionado Visibility="Collapsed" para o terminal já nascer escondido -->
        <Border x:Name="boxTerminal" Grid.Row="2" CornerRadius="6" ClipToBounds="True" Visibility="Collapsed">
            <TextBox x:Name="txtConsole" Background="#181818" Foreground="#D4D4D4" 
                     FontFamily="Consolas" FontSize="12.5" IsReadOnly="True" TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto" Padding="15" BorderThickness="0"/>
        </Border>

        <Grid Grid.Row="3" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Desenvolvido em .NET 6" Foreground="#999" FontSize="11" VerticalAlignment="Center" Margin="0,0,15,0"/>
                
                <!-- Ajustado para iniciar checado (IsChecked="True") e com o texto "Mostrar Terminal" -->
                <ToggleButton x:Name="btnOcultarTerminal" Content="Mostrar Terminal" IsChecked="True" Click="btnOcultarTerminal_Click"
                              Background="Transparent" Foreground="#666" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold" FontSize="12" Margin="0,0,15,0"/>
                
                <Button x:Name="btnAbrirLog" Content="📂 Abrir Pasta de Logs" Click="btnAbrirLog_Click" 
                        Visibility="Collapsed" Background="Transparent" Foreground="#0078D4" BorderThickness="0" 
                        Cursor="Hand" FontWeight="SemiBold" FontSize="12"/>
            </StackPanel>
            
            <Button x:Name="btnDisparar" Content="Iniciar Verificação" 
                    Width="180" Height="38" HorizontalAlignment="Right"
                    Background="#0078D4" Foreground="White" FontWeight="Bold" FontSize="13"
                    Click="btnDisparar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>